# ── Schwab Individual Trader API ─────────────────────────────────
# Create an app at https://developer.schwab.com → Individual Trader API
SCHWAB_TRADER_SCHWAB_APP_KEY=your_app_key_here
SCHWAB_TRADER_SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_TRADER_SCHWAB_CALLBACK_URL=http://127.0.0.1:8000/auth/callback

# ── Anthropic ─────────────────────────────────────────────────────
# https://console.anthropic.com
SCHWAB_TRADER_ANTHROPIC_API_KEY=sk-ant-...

# ── Quiver Quantitative (optional) ────────────────────────────────
# Free API key at https://quiverquant.com — enables congressional trading
# data (Pelosi, all House/Senate members) in the Insiders tab.
SCHWAB_TRADER_QUIVER_QUANT_API_KEY=

# ── Dashboard URL ─────────────────────────────────────────────────
# Used to generate approve/deny links in SMS and email notifications.
# Set to your machine's local IP (e.g. http://192.168.1.10:8000) or
# a public URL if using Tailscale Funnel / ngrok.
SCHWAB_TRADER_DASHBOARD_URL=http://localhost:8000

# ── Twilio SMS alerts (optional) ──────────────────────────────────
# https://console.twilio.com — free trial works fine
SCHWAB_TRADER_TWILIO_ACCOUNT_SID=
SCHWAB_TRADER_TWILIO_AUTH_TOKEN=
SCHWAB_TRADER_TWILIO_FROM_NUMBER=+1xxxxxxxxxx
SCHWAB_TRADER_ALERT_PHONE_NUMBER=+1xxxxxxxxxx

# ── Email notifications (optional) ────────────────────────────────
# SMTP credentials for buy/sell proposal emails with approve/deny buttons.
# Gmail: use an App Password (not your regular password).
SCHWAB_TRADER_EMAIL_SMTP_HOST=smtp.gmail.com
SCHWAB_TRADER_EMAIL_SMTP_PORT=587
SCHWAB_TRADER_EMAIL_SMTP_USER=you@gmail.com
SCHWAB_TRADER_EMAIL_SMTP_PASSWORD=your_app_password_here
SCHWAB_TRADER_ALERT_EMAIL_ADDRESS=you@gmail.com

# ── Buy scan settings ─────────────────────────────────────────────
# Budget per trade (dollars), how often to scan (hours), max proposals per scan
SCHWAB_TRADER_BUY_SCAN_BUDGET=2000
SCHWAB_TRADER_BUY_SCAN_INTERVAL_HOURS=24
SCHWAB_TRADER_BUY_SCAN_MAX_PROPOSALS=3

# Comma-separated tickers the buy scan considers. Edit to match your investment style.
# Examples: tech/semis (default), agriculture (DE,ADM,MOS,NTR,BG), energy (XOM,CVX,SLB)
# SCHWAB_TRADER_BUY_SCAN_WATCHLIST=NVDA,AMD,MSFT,GOOG,META,AMZN,TSLA,QQQ

# Minimum analyst upside % a proposal must have to trigger an email.
# Set to 0 to email on every scan result.
SCHWAB_TRADER_EMAIL_MIN_UPSIDE_PCT=15

# ── FRED API (optional) ───────────────────────────────────────────
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
# Enables macroeconomic indicators (yield curve, CPI, etc.) in the dashboard.
SCHWAB_TRADER_FRED_API_KEY=

# ── Risk guardrails ───────────────────────────────────────────────
# Set LIVE_ORDER_KILL_SWITCH=true to block all live order execution.
SCHWAB_TRADER_LIVE_ORDER_KILL_SWITCH=false
SCHWAB_TRADER_LIVE_ORDER_MAX_DAILY_LOSS_DOLLARS=
SCHWAB_TRADER_LIVE_ORDER_MAX_ORDER_NOTIONAL_DOLLARS=
SCHWAB_TRADER_LIVE_ORDER_MAX_OPEN_POSITIONS=6
SCHWAB_TRADER_LIVE_ORDER_MAX_SINGLE_TRADE_RISK_DOLLARS=
SCHWAB_TRADER_LIVE_ORDER_MAX_SYMBOL_ALLOCATION_PCT=25
SCHWAB_TRADER_LIVE_ORDER_REQUIRE_STOP_LOSS_FOR_ENTRIES=false
SCHWAB_TRADER_REGIME_ENABLED=false

# ── Alert thresholds (defaults shown) ────────────────────────────
SCHWAB_TRADER_ALERT_GAIN_PCT=30
SCHWAB_TRADER_ALERT_POSITION_DOWN_PCT=8
SCHWAB_TRADER_ALERT_DAY_LOSS_PCT=5
SCHWAB_TRADER_ALERT_CONCENTRATION_PCT=25
SCHWAB_TRADER_ALERT_EARNINGS_DAYS=3
SCHWAB_TRADER_AGENT_CHECK_INTERVAL_MINUTES=30

# ── Storage paths (defaults work out of the box) ─────────────────
SCHWAB_TRADER_SCHWAB_TOKEN_PATH=.schwab_token.json
SCHWAB_TRADER_JOURNAL_DATABASE_URL=sqlite:///journal.db
